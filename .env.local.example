# FlexMon Dashboard — Environment Variables

# Password for dashboard access
DASHBOARD_PASSWORD=your_secure_password_here

# Secret key for session JWT (generate with: openssl rand -base64 32)
AUTH_SECRET=your_generated_secret_here

# ENTSO-E Transparency Platform (day-ahead price fallback)
# Register at https://transparency.entsoe.eu/ and request API access
ENTSOE_API_TOKEN=your_entsoe_token_here

# EnergyForecast.de (2-day price forecast)
# Register at https://www.energyforecast.de/
ENERGY_FORECAST_TOKEN=your_energy_forecast_token_here

# Supabase (optional — price caching)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
