# Flex Visualization — Environment Variables
#
# These names also map directly to Azure App Service "Application settings".
# For the current app, all variables below are optional.
# The app can start and serve `/v2` with no custom environment variables.

# Optional: Supabase-backed cache/features
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Optional: set to true to enable GB in the UI and runtime API paths
# ENABLE_GB=true

# Optional: set to true only if you explicitly want to re-enable intraday surfaces
# Leave unset for the current deployment shape.
# ENABLE_INTRADAY=true

# Optional: ENTSO-E Transparency Platform token used for price fallback
# Register at https://transparency.entsoe.eu/ and request API access
ENTSOE_API_TOKEN=your_entsoe_token_here

# Optional: EnergyForecast.de token used for forecast-backed views
# Register at https://www.energyforecast.de/
ENERGY_FORECAST_TOKEN=your_energy_forecast_token_here
